{
	"name": "df_bronze_catalogos_consolidado",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_departamentos_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "catalogo_establecimientos_csv",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "catalogos_vacunas_pai_csv",
						"type": "DatasetReference"
					},
					"name": "source3"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "select2"
				},
				{
					"name": "select3"
				}
			],
			"scriptLines": [
				"source(output(",
				"          municipio_id as string,",
				"          municipio_nombre as string,",
				"          departamento as string,",
				"          codigo_departamento as string,",
				"          zona_geografica as string,",
				"          es_capital_departamental as string,",
				"          poblacion_depto_estimada as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          nivel_atencion as string,",
				"          zona as string,",
				"          sedes as string,",
				"          red_salud as string,",
				"          departamento as string,",
				"          municipio as string,",
				"          latitud as string,",
				"          longitud as string,",
				"          tiene_cadena_frio as string,",
				"          activo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          enfermedad_previene as string,",
				"          grupo_pai as string,",
				"          numero_dosis as string,",
				"          dosis_descripcion as string,",
				"          edad_aplicacion_descripcion as string,",
				"          edad_minima_dias as string,",
				"          edad_maxima_dias as string,",
				"          intervalo_minimo_dias as string,",
				"          via_administracion as string,",
				"          sitio_aplicacion as string,",
				"          dosis_ml as string,",
				"          condicion_especial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source1 select(mapColumn(",
				"          municipio_id,",
				"          municipio_nombre,",
				"          departamento,",
				"          codigo_departamento,",
				"          zona_geografica,",
				"          es_capital_departamental,",
				"          poblacion_depto_estimada",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"source2 select(mapColumn(",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          tipo_establecimiento,",
				"          nivel_atencion,",
				"          zona,",
				"          sedes,",
				"          red_salud,",
				"          departamento,",
				"          municipio,",
				"          latitud,",
				"          longitud,",
				"          tiene_cadena_frio,",
				"          activo",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"source3 select(mapColumn(",
				"          vacuna_id,",
				"          vacuna_nombre,",
				"          enfermedad_previene,",
				"          grupo_pai,",
				"          numero_dosis,",
				"          dosis_descripcion,",
				"          edad_aplicacion_descripcion,",
				"          edad_minima_dias,",
				"          edad_maxima_dias,",
				"          intervalo_minimo_dias,",
				"          via_administracion,",
				"          sitio_aplicacion,",
				"          dosis_ml,",
				"          condicion_especial",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3"
			]
		}
	}
}