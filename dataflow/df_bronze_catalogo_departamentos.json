{
	"name": "df_bronze_catalogo_departamentos",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_departamentos_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_catalogo_departamentos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          municipio_id as string,",
				"          municipio_nombre as string,",
				"          departamento as string,",
				"          codigo_departamento as string,",
				"          zona_geografica as string,",
				"          es_capital_departamental as string,",
				"          poblacion_depto_estimada as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 select(mapColumn(",
				"          municipio_id,",
				"          municipio_nombre,",
				"          departamento,",
				"          codigo_departamento,",
				"          zona_geografica,",
				"          es_capital_departamental,",
				"          poblacion_depto_estimada",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(municipio_nombre = initCap(trim(municipio_nombre)),",
				"          departamento = initCap(trim(departamento)),",
				"          zona_geografica = initCap(trim(zona_geografica)),",
				"          es_capital_departamental = iif(",
				"    in(['si', 'true','1', 'yes'], lower(trim(toString(es_capital_departamental)))), true(), false()),",
				"          poblacion_depto_estimada = toInteger(poblacion_depto_estimada),",
				"          codigo_departamento = case(",
				"    codigo_departamento == 'LP', 'LPZ',",
				"    codigo_departamento == 'SC', 'SCZ',",
				"    codigo_departamento == 'CB', 'CBBA',",
				"    codigo_departamento == 'OR', 'ORU',",
				"    codigo_departamento == 'TJ', 'TJA',",
				"    codigo_departamento",
				")) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          municipio_id as string,",
				"          municipio_nombre as string,",
				"          departamento as string,",
				"          codigo_departamento as string,",
				"          zona_geografica as string,",
				"          es_capital_departamental as boolean,",
				"          poblacion_depto_estimada as integer,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          municipio_id,",
				"          municipio_nombre,",
				"          departamento,",
				"          codigo_departamento,",
				"          zona_geografica,",
				"          es_capital_departamental,",
				"          poblacion_depto_estimada",
				"     )) ~> sink1"
			]
		}
	}
}