{
	"name": "df_gold_dim_vacuna",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_catalogo_vacunas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_vacuna",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          enfermedad_previene as string,",
				"          via_administracion as string,",
				"          es_esquema_regular as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT DISTINCT \\n    vacuna_id, \\n    vacuna_nombre, \\n    enfermedad_previene, \\n    via_administracion, \\n    CASE \\n        WHEN grupo_pai = \\'PAI Regular\\' THEN 1 \\n        ELSE 0 \\n    END AS es_esquema_regular \\nFROM silver.cat_vacunas_pai \\nWHERE vacuna_id IS NOT NULL',",
				"     format: 'query') ~> source1",
				"source1 derive(es_esquema_regular = iif(",
				"    in(['si', 'true','1', 'yes'], lower(trim(toString(es_esquema_regular)))), true(), false())) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          vacuna_key as integer,",
				"          vacuna_id as string,",
				"          nombre_vacuna as string,",
				"          enfermedad_previene as string,",
				"          via_administracion as string,",
				"          es_esquema_regular as boolean",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          vacuna_id,",
				"          nombre_vacuna = vacuna_nombre,",
				"          enfermedad_previene,",
				"          via_administracion,",
				"          es_esquema_regular",
				"     )) ~> sink1"
			]
		}
	}
}