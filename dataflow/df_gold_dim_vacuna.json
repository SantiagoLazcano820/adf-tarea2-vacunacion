{
	"name": "df_gold_dim_vacuna",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_catalogo_vacunas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_vacuna",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          enfermedad_previene as string,",
				"          via_administracion as string,",
				"          es_esquema_regular as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT DISTINCT vacuna_id, vacuna_nombre, enfermedad_previene, via_administracion, CASE WHEN grupo_pai = \\'PAI Regular\\' THEN 1 ELSE 0 END AS es_esquema_regular FROM silver.cat_vacunas_pai WHERE vacuna_id IS NOT NULL',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          vacuna_key as integer,",
				"          vacuna_id as string,",
				"          nombre_vacuna as string,",
				"          enfermedad_previene as string,",
				"          via_administracion as string,",
				"          es_esquema_regular as boolean",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          vacuna_id,",
				"          nombre_vacuna = vacuna_nombre,",
				"          enfermedad_previene,",
				"          via_administracion",
				"     )) ~> sink1"
			]
		}
	}
}