{
	"name": "df_bronze_catalogo_establecimientos",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_establecimientos_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_catalogo_establecimientos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          nivel_atencion as string,",
				"          zona as string,",
				"          sedes as string,",
				"          red_salud as string,",
				"          departamento as string,",
				"          municipio as string,",
				"          latitud as string,",
				"          longitud as string,",
				"          tiene_cadena_frio as string,",
				"          activo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 select(mapColumn(",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          departamento,",
				"          municipio_nombre = municipio,",
				"          tiene_cadena_frio,",
				"          activo",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(nombre_establecimiento = initCap(trim(nombre_establecimiento)),",
				"          tiene_cadena_frio = iif(     in(['si', 'true','1', 'yes'], lower(trim(toString(tiene_cadena_frio)))), true(), false()),",
				"          activo = iif(     in(['si', 'true','1', 'yes'], lower(trim(toString(activo)))), true(), false()),",
				"          municipio_nombre = initCap(trim(municipio_nombre))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_catalogo as integer,",
				"          departamento as string,",
				"          establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          vacuna as string,",
				"          tipo_vacuna as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          departamento",
				"     )) ~> sink1"
			]
		}
	}
}