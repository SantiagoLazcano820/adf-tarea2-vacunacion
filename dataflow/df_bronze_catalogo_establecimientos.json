{
	"name": "df_bronze_catalogo_establecimientos",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_establecimientos_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "silver_catalogo_departamentos",
						"type": "DatasetReference"
					},
					"name": "source2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_catalogo_establecimientos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "lookup1"
				},
				{
					"name": "select2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          nivel_atencion as string,",
				"          zona as string,",
				"          sedes as string,",
				"          red_salud as string,",
				"          departamento as string,",
				"          municipio as string,",
				"          latitud as string,",
				"          longitud as string,",
				"          tiene_cadena_frio as string,",
				"          activo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          municipio_id as string,",
				"          municipio_nombre as string,",
				"          departamento as string,",
				"          codigo_departamento as string,",
				"          zona_geografica as string,",
				"          es_capital_departamental as boolean,",
				"          poblacion_depto_estimada as integer,",
				"          fecha_carga as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source1 select(mapColumn(",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          departamento,",
				"          municipio_nombre = municipio,",
				"          tiene_cadena_frio,",
				"          activo",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(nombre_establecimiento = initCap(trim(nombre_establecimiento)),",
				"          tiene_cadena_frio = iif(     in(['si', 'true','1', 'yes'], lower(trim(toString(tiene_cadena_frio)))), true(), false()),",
				"          activo = iif(     in(['si', 'true','1', 'yes'], lower(trim(toString(activo)))), true(), false()),",
				"          municipio_nombre = initCap(trim(municipio_nombre))) ~> derivedColumn1",
				"derivedColumn1, source2 lookup(derivedColumn1@municipio_nombre == source2@municipio_nombre,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1 select(mapColumn(",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          departamento = select1@departamento,",
				"          municipio_nombre = derivedColumn1@municipio_nombre,",
				"          tiene_cadena_frio,",
				"          activo,",
				"          municipio_id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          departamento as string,",
				"          municipio_id as string,",
				"          municipio_nombre as string,",
				"          tiene_cadena_frio as boolean,",
				"          activo as boolean,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          departamento,",
				"          municipio_id,",
				"          municipio_nombre,",
				"          tiene_cadena_frio,",
				"          activo",
				"     )) ~> sink1"
			]
		}
	}
}