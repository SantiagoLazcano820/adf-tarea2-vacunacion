{
	"name": "df_bronze_vacunacion_consolidado",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "vacunacion_la_paz_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "vacunacion_santa_cruz_csv",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "vacunacion_rural_movil_csv",
						"type": "DatasetReference"
					},
					"name": "source3"
				},
				{
					"dataset": {
						"referenceName": "silver_catalogo_vacunas",
						"type": "DatasetReference"
					},
					"name": "source4"
				},
				{
					"dataset": {
						"referenceName": "silver_catalogo_establecimientos",
						"type": "DatasetReference"
					},
					"name": "source5"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "select2"
				},
				{
					"name": "select3"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "union1"
				},
				{
					"name": "union2"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "lookup1"
				},
				{
					"name": "lookup2"
				},
				{
					"name": "select4"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_registro as string,",
				"          cod_paciente as string,",
				"          documento_identidad as string,",
				"          nombres as string,",
				"          primer_apellido as string,",
				"          segundo_apellido as string,",
				"          genero as string,",
				"          fec_nacimiento as string,",
				"          municipio as string,",
				"          pueblo_indigena as string,",
				"          fec_vacunacion as string,",
				"          cod_vacuna as string,",
				"          desc_vacuna as string,",
				"          nro_dosis as string,",
				"          cod_establecimiento as string,",
				"          desc_establecimiento as string,",
				"          depto as string,",
				"          nro_lote as string,",
				"          temp_conservacion as string,",
				"          edad_dias as string,",
				"          via_aplicacion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          registro_id as string,",
				"          paciente_id as string,",
				"          ci_paciente as string,",
				"          nombre_paciente as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          sexo as string,",
				"          fecha_nacimiento as string,",
				"          municipio_residencia as string,",
				"          comunidad_indigena as string,",
				"          fecha_vacunacion as string,",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          numero_dosis as string,",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          departamento as string,",
				"          lote_vacuna as string,",
				"          temperatura_conservacion as string,",
				"          edad_dias_aplicacion as string,",
				"          aplicacion_oportuna as string,",
				"          via_administracion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          record_id as string,",
				"          sync_timestamp as string,",
				"          device_id as string,",
				"          patient_id as string,",
				"          patient_ci as string,",
				"          patient_name as string,",
				"          patient_last_name_1 as string,",
				"          patient_last_name_2 as string,",
				"          patient_sex as string,",
				"          patient_birth_date as string,",
				"          patient_department as string,",
				"          patient_municipality as string,",
				"          patient_community as string,",
				"          patient_indigenous as string,",
				"          vaccination_date as string,",
				"          vaccine_code as string,",
				"          vaccine_name as string,",
				"          dose_number as string,",
				"          facility_code as string,",
				"          facility_name as string,",
				"          lot_number as string,",
				"          storage_temp_celsius as string,",
				"          patient_age_days as string,",
				"          administration_route as string,",
				"          gps_latitude as string,",
				"          gps_longitude as string,",
				"          gps_accuracy_meters as string,",
				"          observations as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source(output(",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          enfermedad_previene as string,",
				"          grupo_pai as string,",
				"          numero_dosis as integer,",
				"          dosis_descripcion as string,",
				"          edad_aplicacion_descripcion as string,",
				"          via_administracion as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source4",
				"source(output(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          departamento as string,",
				"          municipio_id as string,",
				"          municipio_nombre as string,",
				"          tiene_cadena_frio as boolean,",
				"          activo as boolean,",
				"          fecha_carga as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source5",
				"source1 select(mapColumn(",
				"          id_transaccional_origen = id_registro,",
				"          paciente_id = cod_paciente,",
				"          genero,",
				"          fecha_vacunacion = fec_vacunacion,",
				"          dosis = nro_dosis,",
				"          lote_nro = nro_lote,",
				"          temperatura_conservacion = temp_conservacion,",
				"          origen_datos = depto,",
				"          vacuna_nombre = desc_vacuna,",
				"          establecimiento_nombre = desc_establecimiento",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"source3 select(mapColumn(",
				"          id_transaccional_origen = record_id,",
				"          paciente_id = patient_id,",
				"          genero = patient_sex,",
				"          origen_datos = patient_department,",
				"          fecha_vacunacion = vaccination_date,",
				"          dosis = dose_number,",
				"          lote_nro = lot_number,",
				"          temperatura_conservacion = storage_temp_celsius,",
				"          vacuna_nombre = vaccine_name,",
				"          establecimiento_nombre = facility_name",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"source2 select(mapColumn(",
				"          id_transaccional_origen = registro_id,",
				"          paciente_id,",
				"          genero = sexo,",
				"          fecha_vacunacion,",
				"          dosis = numero_dosis,",
				"          origen_datos = departamento,",
				"          lote_nro = lote_vacuna,",
				"          temperatura_conservacion,",
				"          vacuna_nombre,",
				"          establecimiento_nombre = nombre_establecimiento",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"select1 derive(origen_datos = \"LPZ\") ~> derivedColumn1",
				"select3 derive(origen_datos = \"SCZ\") ~> derivedColumn2",
				"select2 derive(origen_datos = \"RURAL\") ~> derivedColumn3",
				"derivedColumn1, derivedColumn2 union(byName: true)~> union1",
				"union1, derivedColumn3 union(byName: true)~> union2",
				"union2 derive(fecha_vacunacion = coalesce(",
				"    coalesce (",
				"        toDate (fecha_vacunacion, 'yyyy-MM-dd'),",
				"        toDate (fecha_vacunacion, 'dd/MM/yyyy'),",
				"        toDate (fecha_vacunacion, 'MM-dd-yyyy'),",
				"        toDate (fecha_vacunacion, 'yyyy/MM/dd'),",
				"        toDate (fecha_vacunacion, 'dd-MMM-yyyy'),",
				"        toDate (fecha_vacunacion, 'MMMM dd, yyyy'),",
				"        toDate (fecha_vacunacion, \"dd 'de' MMMM 'de' yyyy\")",
				"    ),",
				"    toDate('1900-01-01', 'yyyy-MM-dd')",
				"),",
				"          dosis = toInteger(toDecimal(dosis, 10, 2)),",
				"          temperatura_conservacion = toDecimal(temperatura_conservacion, 5, 2),",
				"          genero = iif(",
				"    in(['femenino', 'F', 'mujer', 'female'], lower(trim(genero))), ",
				"    'Femenino', ",
				"    iif(",
				"        in(['masculino', 'M', 'hombre', 'male'], lower(trim(genero))), ",
				"        'Masculino', ",
				"        'No especificado'",
				"    )",
				"),",
				"          vacuna_nombre = initCap(trim(vacuna_nombre)),",
				"          establecimiento_nombre = initCap(trim(establecimiento_nombre))) ~> derivedColumn4",
				"derivedColumn4, source4 lookup(derivedColumn4@vacuna_nombre == source4@vacuna_nombre,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1, source5 lookup(establecimiento_nombre == nombre_establecimiento,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup2",
				"lookup2 select(mapColumn(",
				"          id_transaccional_origen,",
				"          paciente_id,",
				"          genero,",
				"          fecha_vacunacion,",
				"          dosis,",
				"          lote_nro,",
				"          temperatura_conservacion,",
				"          origen_datos,",
				"          vacuna_nombre = derivedColumn4@vacuna_nombre,",
				"          establecimiento_nombre,",
				"          vacuna_id,",
				"          establecimiento_id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4"
			]
		}
	}
}